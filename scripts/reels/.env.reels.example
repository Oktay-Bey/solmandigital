# Solman Digital — Reels Otomasyonu env şablonu
# Kopyala: cp .env.reels.example .env.reels  → değerleri doldur.
# .env.reels GIT-IGNORED'dır; token'ları repoya KOYMA.

# ── OpenAI (içerik + TTS) ─────────────────────────────────────
OPENAI_API_KEY=

# ── YouTube (get-youtube-tokens.mjs çıktısı) ──────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Meta / Instagram + Facebook (get-meta-token.mjs çıktısı) ──
# Tek app modu: META_PAGE_ACCESS_TOKEN + META_PAGE_ID + META_IG_USER_ID
# Ayrı app modu: META_IG_TOKEN / META_FB_TOKEN ayrı verilebilir.
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=

# ── Site + public video host (Meta video'yu URL'den çeker) ────
NEXT_PUBLIC_SITE_URL=https://solmandigital.com
# Seçenek A (hızlı): NewsMotor/TroyWire VPS public klasörünü ortak kullan.
# Video yalnızca upload anında oraya kopyalanır, sonra silinir.
PUBLIC_REELS_DIR=
PUBLIC_REELS_BASEURL=
